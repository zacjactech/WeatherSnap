<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WeatherSnap.Starting" parent="Theme.SplashScreen">
        <!-- Background color of the splash screen -->
        <item name="windowSplashScreenBackground">#12141D</item>
        <!-- The icon to display in the center -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- The theme to switch to after the splash screen is done -->
        <item name="postSplashScreenTheme">@android:style/Theme.Material.NoActionBar</item>
    </style>
</resources>
